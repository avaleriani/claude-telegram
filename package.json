{
  "name": "claude-telegram",
  "version": "1.0.0",
  "description": "Use Claude Code from your phone. Telegram bridge to the CLI — one file, no frameworks.",
  "main": "claude-server.js",
  "bin": {
    "claude-telegram": "claude-server.js"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "telegram-bot",
    "claude",
    "anthropic",
    "ai",
    "cli",
    "remote",
    "mobile",
    "nodejs",
    "developer-tools"
  ],
  "scripts": {
    "go": "node claude-server.js --setup",
    "start": "node claude-server.js --start",
    "dev": "node claude-server.js --dev",
    "stop": "node claude-server.js --stop",
    "logs": "node claude-server.js --logs",
    "restart": "node claude-server.js --stop && node claude-server.js --start"
  },
  "files": [
    "claude-server.js",
    ".env.example",
    "README.md"
  ]
}
