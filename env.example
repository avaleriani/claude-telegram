# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Default project directory (absolute path)
PROJECT_DIR=/path/to/your/project

# Parent folder to scan for projects (used by /project picker)
PROJECTS_DIR=/path/to/your/projects

# Comma-separated Telegram chat IDs allowed to use the bot
# The setup wizard detects your ID automatically
ALLOWED_CHATS=

# How much tool output to show in Telegram
# Options: all, condensed, quiet
VERBOSITY=condensed

# How much access Claude gets to your system
#
# Options:
#   bypassPermissions  - Full access: read, write, run any command (default)
#   acceptEdits        - Can read and edit files, only approved shell commands
#   plan               - Read-only: Claude suggests changes but can't modify anything
#   default            - Claude CLI's default behavior
#   auto               - Automatic permission handling
#   dontAsk            - Never prompt, deny anything that would need approval
PERMISSION_MODE=bypassPermissions
