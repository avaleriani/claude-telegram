# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-token-here

# Default project directory (absolute path)
PROJECT_DIR=/path/to/your/project

# Parent folder containing your projects (for /project picker)
PROJECTS_DIR=/path/to/your/projects

# Comma-separated Telegram chat IDs allowed to use the bot
ALLOWED_CHATS=123456789

# How much tool output to show: all | condensed | quiet
VERBOSITY=condensed

# How much access Claude gets:
#   bypassPermissions - full access (read, write, run commands)
#   acceptEdits       - read + edit files, approved commands only
#   plan              - read only, Claude suggests but can't modify
PERMISSION_MODE=bypassPermissions

# Show modified files buttons after Claude finishes: true | false
SHOW_MODIFIED_FILES=false
